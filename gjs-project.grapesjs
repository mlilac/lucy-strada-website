agnadas, maximizar o sucesso, melhorar os relacionamentos, implementar a saúde e até mesmo engravidar. "}]}]},{"type":"link","editable":false,"classes":["framer-xrtynf","framer-1sqjor8"],"attributes":{"data-framer-appear-id":"xrtynf","data-framer-name":"Button","href":"https://lucystrada.substack.com/p/portais-de-bencaos-ativados-nos-imoveis?r=1vm0qr","rel":"noopener","id":"ivi73w"},"components":[{"classes":["framer-d4fmnr"],"attributes":{"data-framer-component-type":"RichTextContainer","id":"i836nj"},"components":[{"tagName":"p","type":"text","classes":["framer-text"],"attributes":{"id":"ikx0sh"},"components":[{"type":"textnode","content":"Saiba Mais"}]}]}]}]}]}]},{"classes":["framer-119xlos-container"],"attributes":{"data-framer-name":"numerologia","name":"numerologia","id":"im2lw2"},"components":[{"classes":["framer-rTGZS","framer-HVLlm","framer-GdevH","framer-1owqart","framer-v-1owqart"],"attributes":{"name":"numerologia","data-framer-name":"Desktop","id":"ikjzbm"},"components":[{"classes":["framer-pruedm"],"attributes":{"id":"is1bjj"},"components":[{"classes":["framer-1r4lnvt"],"attributes":{"data-framer-name":"Gradient","id":"i054mf"}},{"classes":["framer-y4eqsl"],"attributes":{"data-framer-name":"Image","id":"iq84md"},"components":[{"attributes":{"data-framer-background-image-wrapper":"true","id":"i3gnkj"},"components":[{"type":"image","resizable":{"ratioDefault":1},"attributes":{"decoding":"auto","width":"100","height":"328","sizes":"100px","srcset":"https://framerusercontent.com/images/8N0yWW6MUh1H5Iaa276SQ6QYY.jpg?scale-down-to=512&width=1024&height=768 512w, https://framerusercontent.com/images/8N0yWW6MUh1H5Iaa276SQ6QYY.jpg?width=1024&height=768 1024w","src":"https://lucystrada.com/index_files/8N0yWW6MUh1H5Iaa276SQ6QYY.jpg","alt":"","id":"ilxrnm"}}]}]}]},{"classes":["framer-ysjvn"],"attributes":{"id":"incqf5"},"components":[{"classes":["framer-13olohv"],"attributes":{"data-framer-component-type":"RichTextContainer","id":"ix2w5h"},"components":[{"tagName":"h3","type":"heading","classes":["framer-text","framer-styles-preset-1rsa1iv"],"attributes":{"data-styles-preset":"PRDGHKU_m"},"components":[{"type":"textnode","content":"Direção Favorável para Mudanças"}]}]},{"classes":["framer-16139vn"],"attributes":{"data-framer-component-type":"RichTextContainer","id":"i3otnk"},"components":[{"tagName":"p","type":"text","classes":["framer-text","framer-styles-preset-e7e1gy"],"attributes":{"data-styles-preset":"iUCwKohD7"},"components":[{"type":"textnode","content":"Com base na Astrologia Imperial, essa técnica revela as direções mais prósperas para mudanças, viagens ou novos começos. Ao alinhar seu movimento com o fluxo energético do seu mapa astral de Zi Wei Dou Shu, você aumenta as chances de sucesso, bem-estar e realizações. Ideal para quem busca um recomeço com mais consciência e harmonia."}]}]},{"type":"link","editable":false,"classes":["framer-xrtynf","framer-1sqjor8"],"attributes":{"data-framer-appear-id":"xrtynf","data-framer-name":"Button","href":"https://lucystrada.substack.com/p/direcao-favoravel-para-viagens-ou?r=1vm0qr","rel":"noopener","id":"i2kcu3"},"components":[{"classes":["framer-d4fmnr"],"attributes":{"data-framer-component-type":"RichTextContainer","id":"ikxzlm"},"components":[{"tagName":"p","type":"text","classes":["framer-text"],"attributes":{"id":"iaah3t"},"components":[{"type":"textnode","content":"Saiba Mais"}]}]}]}]}]}]},{"classes":["framer-9d6xkl-container"],"attributes":{"data-framer-name":"numerologia","name":"numerologia","id":"iqayrn"},"components":[{"classes":["framer-rTGZS","framer-HVLlm","framer-GdevH","framer-1owqart","framer-v-1owqart"],"attributes":{"name":"numerologia","data-framer-name":"Desktop","id":"iahgon"},"components":[{"classes":["framer-pruedm"],"attributes":{"id":"i2mld7"},"components":[{"classes":["framer-1r4lnvt"],"attributes":{"data-framer-name":"Gradient","id":"iqja2w"}},{"classes":["framer-y4eqsl"],"attributes":{"data-framer-name":"Image","id":"i6yalt"},"components":[{"attributes":{"data-framer-background-image-wrapper":"true","id":"iol4at"},"components":[{"type":"image","resizable":{"ratioDefault":1},"attributes":{"decoding":"auto","width":"100","height":"352","sizes":"100px","srcset":"https://framerusercontent.com/images/8N0yWW6MUh1H5Iaa276SQ6QYY.jpg?scale-down-to=512&width=1024&height=768 512w, https://framerusercontent.com/images/8N0yWW6MUh1H5Iaa276SQ6QYY.jpg?width=1024&height=768 1024w","src":"https://lucystrada.com/index_files/8N0yWW6MUh1H5Iaa276SQ6QYY.jpg","alt":"","id":"itgitb"}}]}]}]},{"classes":["framer-ysjvn"],"attributes":{"id":"ibh0xk"},"components":[{"classes":["framer-13olohv"],"attributes":{"data-framer-component-type":"RichTextContainer","id":"i9lkst"},"components":[{"tagName":"h3","type":"heading","classes":["framer-text","framer-styles-preset-1rsa1iv"],"attributes":{"data-styles-preset":"PRDGHKU_m"},"components":[{"type":"textnode","content":"Portal de Aniversário"}]}]},{"classes":["framer-16139vn"],"attributes":{"data-framer-component-type":"RichTextContainer","id":"i4cjos"},"components":[{"tagName":"p","type":"text","classes":["framer-text","framer-styles-preset-e7e1gy"],"attributes":{"data-styles-preset":"iUCwKohD7"},"components":[{"type":"textnode","content":"No seu aniversário, uma simples viagem na direção certa — calculada pelo seu mapa pessoal de Zi Wei Dou Shu — pode abrir um portal de oportunidades para os próximos 12 meses. Essa técnica milenar pode ser usada para ativar sorte, prosperidade, saúde, relacionamentos e novos começos. Uma maneira especial de iniciar o novo ciclo com mais propósito e energia."}]}]},{"type":"link","editable":false,"classes":["framer-xrtynf","framer-1sqjor8"],"attributes":{"data-framer-appear-id":"xrtynf","data-framer-name":"Button","href":"https://lucystrada.substack.com/p/abra-um-portal-de-bencaos-no-seu?r=1vm0qr","rel":"noopener","id":"ig5y6m"},"components":[{"classes":["framer-d4fmnr"],"attributes":{"data-framer-component-type":"RichTextContainer","id":"iblob6"},"components":[{"tagName":"p","type":"text","classes":["framer-text"],"attributes":{"id":"itxlpq"},"components":[{"type":"textnode","content":"Saiba Mais"}]}]}]}]}]}]},{"classes":["framer-1uzjj3c-container"],"attributes":{"data-framer-name":"numerologia","name":"numerologia"},"components":[{"classes":["framer-rTGZS","framer-HVLlm","framer-GdevH","framer-1owqart","framer-v-1owqart"],"attributes":{"name":"numerologia","data-framer-name":"Desktop","id":"ihwsg2"},"components":[{"classes":["framer-pruedm"],"attributes":{"id":"ii41k4"},"components":[{"classes":["framer-1r4lnvt"],"attributes":{"data-framer-name":"Gradient","id":"iix8jh"}},{"classes":["framer-y4eqsl"],"attributes":{"data-framer-name":"Image","id":"ixttik"},"components":[{"attributes":{"data-framer-background-image-wrapper":"true","id":"iq9brl"},"components":[{"type":"image","resizable":{"ratioDefault":1},"attributes":{"decoding":"auto","width":"100","height":"328","sizes":"100px","srcset":"https://framerusercontent.com/images/8N0yWW6MUh1H5Iaa276SQ6QYY.jpg?scale-down-to=512&width=1024&height=768 512w, https://framerusercontent.com/images/8N0yWW6MUh1H5Iaa276SQ6QYY.jpg?width=1024&height=768 1024w","src":"https://lucystrada.com/index_files/8N0yWW6MUh1H5Iaa276SQ6QYY.jpg","alt":"","id":"ip7l3i"}}]}]}]},{"classes":["framer-ysjvn"],"attributes":{"id":"ivuohg"},"components":[{"classes":["framer-13olohv"],"attributes":{"data-framer-component-type":"RichTextContainer","id":"isxu21"},"components":[{"tagName":"h3","type":"heading","classes":["framer-text","framer-styles-preset-1rsa1iv"],"attributes":{"data-styles-preset":"PRDGHKU_m"},"components":[{"type":"textnode","content":"Cálculo de Datas Propícias"}]}]},{"classes":["framer-16139vn"],"attributes":{"data-framer-component-type":"RichTextContainer","id":"iphjvf"},"components":[{"tagName":"p","type":"text","classes":["framer-text","framer-styles-preset-e7e1gy"],"attributes":{"data-styles-preset":"iUCwKohD7"},"components":[{"type":"textnode","content":"Analisamos diferentes sistemas esotéricos e astrológicos para identificar os momentos favoráveis para eventos importantes, como mudanças de residências ou empresas, assinatura de contratos, registro de empresa, casamento, viagens, imigração, batizados e qualquer outro evento ou situação de mudança que possa interferir de forma significativa no fluxo da vida."}]}]},{"type":"link","editable":false,"classes":["framer-xrtynf","framer-1sqjor8"],"attributes":{"data-framer-appear-id":"xrtynf","data-framer-name":"Button","href":"https://lucystrada.substack.com/p/calculo-de-datas-propicias?r=1vm0qr","rel":"noopener","id":"i56fdk"},"components":[{"classes":["framer-d4fmnr"],"attributes":{"data-framer-component-type":"RichTextContainer","id":"iv7v01"},"components":[{"tagName":"p","type":"text","classes":["framer-text"],"attributes":{"id":"ivtfy5"},"components":[{"type":"textnode","content":"Saiba Mais"}]}]}]}]}]}]},{"classes":["framer-1oxh7nu-container"],"attributes":{"data-framer-name":"numerologia","name":"numerologia"},"components":[{"classes":["framer-rTGZS","framer-HVLlm","framer-GdevH","framer-1owqart","framer-v-1owqart"],"attributes":{"name":"numerologia","data-framer-name":"Desktop","id":"ioyf7c"},"components":[{"classes":["framer-pruedm"],"attributes":{"id":"ieqxqu"},"components":[{"classes":["framer-1r4lnvt"],"attributes":{"data-framer-name":"Gradient","id":"is1exl"}},{"classes":["framer-y4eqsl"],"attributes":{"data-framer-name":"Image","id":"idalw4"},"components":[{"attributes":{"data-framer-background-image-wrapper":"true","id":"iyqzhf"},"components":[{"type":"image","resizable":{"ratioDefault":1},"attributes":{"decoding":"auto","width":"100","height":"328","sizes":"100px","srcset":"https://framerusercontent.com/images/8N0yWW6MUh1H5Iaa276SQ6QYY.jpg?scale-down-to=512&width=1024&height=768 512w, https://framerusercontent.com/images/8N0yWW6MUh1H5Iaa276SQ6QYY.jpg?width=1024&height=768 1024w","src":"https://lucystrada.com/index_files/8N0yWW6MUh1H5Iaa276SQ6QYY.jpg","alt":"","id":"ifv45b"}}]}]}]},{"classes":["framer-ysjvn"],"attributes":{"id":"i3xayl"},"components":[{"classes":["framer-13olohv"],"attributes":{"data-framer-component-type":"RichTextContainer","id":"iunpw4"},"components":[{"tagName":"h3","type":"heading","classes":["framer-text","framer-styles-preset-1rsa1iv"],"attributes":{"data-styles-preset":"PRDGHKU_m"},"components":[{"type":"textnode","content":"Cura Reconectiva"}]}]},{"classes":["framer-16139vn"],"attributes":{"data-framer-component-type":"RichTextContainer","id":"ic17gf"},"components":[{"tagName":"p","type":"text","classes":["framer-text","framer-styles-preset-e7e1gy"],"attributes":{"data-styles-preset":"iUCwKohD7"},"components":[{"type":"textnode","content":"Essa técnica vai além do que imaginamos ser possível. Quando nos conectamos a essa frequência de cura, sem tentar controlar o resultado, nosso corpo e vida encontram um equilíbrio natural, promovendo bem-estar físico, emocional e espiritual de forma simples e profunda. Os atendimentos acontecem unicamente à distância, em dia e hora combinados previamente."}]}]},{"type":"link","editable":false,"classes":["framer-xrtynf","framer-1sqjor8"],"attributes":{"data-framer-appear-id":"xrtynf","data-framer-name":"Button","href":"https://lucystrada.substack.com/p/sobre-a-cura-reconectiva?r=1vm0qr","rel":"noopener","id":"ipcgc2"},"components":[{"classes":["framer-d4fmnr"],"attributes":{"data-framer-component-type":"RichTextContainer","id":"ie0mib"},"components":[{"tagName":"p","type":"text","classes":["framer-text"],"attributes":{"id":"iyxyi6"},"components":[{"type":"textnode","content":"Saiba Mais"}]}]}]}]}]}]},{"classes":["framer-1jnlhbg-container"],"attributes":{"data-framer-name":"numerologia","name":"numerologia"},"components":[{"classes":["framer-rTGZS","framer-HVLlm","framer-GdevH","framer-1owqart","framer-v-1owqart"],"attributes":{"name":"numerologia","data-framer-name":"Desktop","id":"isfsse"},"components":[{"classes":["framer-pruedm"],"attributes":{"id":"ifuajj"},"components":[{"classes":["framer-1r4lnvt"],"attributes":{"data-framer-name":"Gradient","id":"ifrmql"}},{"classes":["framer-y4eqsl"],"attributes":{"data-framer-name":"Image","id":"i4u7ct"},"components":[{"attributes":{"data-framer-background-image-wrapper":"true","id":"ilzl82"},"components":[{"type":"image","resizable":{"ratioDefault":1},"attributes":{"decoding":"auto","width":"100","height":"380","sizes":"100px","srcset":"https://framerusercontent.com/images/8N0yWW6MUh1H5Iaa276SQ6QYY.jpg?scale-down-to=512&width=1024&height=768 512w, https://framerusercontent.com/images/8N0yWW6MUh1H5Iaa276SQ6QYY.jpg?width=1024&height=768 1024w","src":"https://lucystrada.com/index_files/8N0yWW6MUh1H5Iaa276SQ6QYY.jpg","alt":"","id":"istvbf"}}]}]}]},{"classes":["framer-ysjvn"],"attributes":{"id":"izlixp"},"components":[{"classes":["framer-13olohv"],"attributes":{"data-framer-component-type":"RichTextContainer","id":"iph4pb"},"components":[{"tagName":"h3","type":"heading","classes":["framer-text","framer-styles-preset-1rsa1iv"],"attributes":{"data-styles-preset":"PRDGHKU_m"},"components":[{"type":"textnode","content":"Um Livro de Luz – 52 Passos para uma Nova Vida"}]}]},{"classes":["framer-16139vn"],"attributes":{"data-framer-component-type":"RichTextContainer","id":"iraqeg"},"components":[{"tagName":"p","type":"text","classes":["framer-text","framer-styles-preset-e7e1gy"],"attributes":{"data-styles-preset":"iUCwKohD7"},"components":[{"type":"textnode","content":"Um manual de transformação com exercícios práticos para quem sente que é hora de mudar. Através de 52 exercícios, que, se realizados com total comprometimento pessoal, oportunizam a Manifestação de uma Nova Vida. Pequenos passos, grandes mudanças. Para viver com mais leveza, saúde, alegria e propósito. Uma jornada real, feita por quem viveu cada etapa e aprendeu a dar um Passo Adiante."}]}]},{"type":"link","editable":false,"classes":["framer-xrtynf","framer-1sqjor8"],"attributes":{"data-framer-appear-id":"xrtynf","data-framer-name":"Button","href":"https://lucystrada.substack.com/p/um-livro-de-luz?r=1vm0qr","rel":"noopener","id":"iag4t4"},"components":[{"classes":["framer-d4fmnr"],"attributes":{"data-framer-component-type":"RichTextContainer","id":"i1fy4g"},"components":[{"tagName":"p","type":"text","classes":["framer-text"],"attributes":{"id":"iomtx8"},"components":[{"type":"textnode","content":"Saiba Mais"}]}]}]}]}]}]}]}]}],"custom-name":"other works section"},{"tagName":"section","classes":["framer-1l6sgo6"],"attributes":{"data-framer-name":"MAPAS 2","id":"i9bf02"},"components":[{"classes":["framer-gs9t9z"],"attributes":{"data-framer-component-type":"RichTextContainer","id":"ict8nf"},"components":[{"tagName":"h3","type":"heading","classes":["framer-text","framer-styles-preset-1rsa1iv"],"attributes":{"data-styles-preset":"PRDGHKU_m","id":"ileqoc"},"components":[{"tagName":"strong","type":"text","classes":["framer-text"],"attributes":{"id":"idd5du"},"components":[{"type":"textnode","content":"Por que integrar diversas técnicas?"},{"tagName":"br","void":true,"classes":["framer-text"]}]},{"tagName":"br","void":true,"classes":["framer-text"]},{"type":"textnode","content":"A integração de técnicas na "},{"tagName":"strong","type":"text","classes":["framer-text"],"attributes":{"id":"ij845w"},"components":[{"type":"textnode","content":"M.A.P.A.S."}]},{"type":"textnode","content":" é essencial porque a vida é interconectada e multidimensional. Cada método revela uma camada distinta — "},{"tagName":"strong","type":"text","classes":["framer-text"],"attributes":{"id":"i2qgyp"},"components":[{"type":"textnode","content":"astrológica, energética, psicológica, espiritual ou ambiental"}]},{"type":"textnode","content":" — e, juntos, oferecem um diagnóstico completo e soluções alinhadas. Só assim é possível "},{"tagName":"strong","type":"text","classes":["framer-text"],"components":[{"type":"textnode","content":"transformar bloqueios invisíveis "}]},{"type":"textnode","content":"em fluxo, harmonizando mente, corpo, espírito e espaço em um "},{"tagName":"strong","type":"text","classes":["framer-text"],"components":[{"type":"textnode","content":"caminho de evolução integral."}]}]}]}],"custom-name":"por que"},{"classes":["framer-ai8k9h"],"attributes":{"data-framer-name":"Quem é Lucy Strada","id":"ixn1w8"},"components":[{"classes":["framer-13f6k3v"],"attributes":{"data-framer-name":"about 1","id":"is6g64"},"components":[{"classes":["framer-tafl9c"],"attributes":{"data-framer-name":"image"},"components":[{"classes":["framer-1vnig1i"],"attributes":{"data-framer-name":"Image Box","id":"i9u3nm"},"components":[{"classes":["framer-1aulup9"],"attributes":{"data-framer-name":"Image"},"components":[{"attributes":{"data-framer-background-image-wrapper":"true","id":"idsgne"},"components":[{"type":"image","resizable":{"ratioDefault":1},"attributes":{"decoding":"auto","width":"460","height":"532","sizes":"252px","srcset":"https://framerusercontent.com/images/KCdvxlyHlsBLHMu62oTydDHILI.jpeg?scale-down-to=1024&width=1265&height=1600 809w, https://framerusercontent.com/images/KCdvxlyHlsBLHMu62oTydDHILI.jpeg?width=1265&height=1600 1265w","src":"https://lucystrada.com/index_files/KCdvxlyHlsBLHMu62oTydDHILI.jpeg","alt":"About Image","id":"i0p5rh"}}]},{"classes":["framer-1gkp7ep"],"attributes":{"data-framer-name":"Signature"},"components":[{"classes":["framer-13yxixj"],"attributes":{"data-framer-component-type":"RichTextContainer","id":"iiltkn"},"components":[{"tagName":"p","type":"text","classes":["framer-text"],"attributes":{"id":"in21sq"},"components":[{"type":"textnode","content":"Lucy Strada"}]}]}]}]}]}]},{"classes":["framer-eev1k1"],"attributes":{"data-framer-name":"text 1"},"components":[{"classes":["framer-j8ci8t"],"attributes":{"data-framer-component-type":"RichTextContainer","id":"iatp33"},"components":[{"tagName":"p","type":"text","classes":["framer-text","framer-styles-preset-1pwd9y3"],"attributes":{"data-styles-preset":"sygriTHMJ","id":"iljawi"},"components":[{"type":"textnode","content":"Sob a perspectiva da personalidade, sou uma sagitariana, intensa e apaixonada pela vida, gaúcha, astróloga há mais de 30 anos. Minha história com os astros começou na adolescência, inspirada por meu pai. Aos 14 anos meu primeiro mapa astral abriu um universo: a possibilidade de \"ler a vida\" e encontrar meu propósito."},{"tagName":"br","void":true,"classes":["framer-text"]},{"tagName":"br","void":true,"classes":["framer-text"]},{"type":"textnode","content":"Formada em Comunicação Social com Pós Graduação em Psicologia Transpessoal, minha busca incessante por respostas da alma me levou a mais de 40 especializações em neurociência, saúde e espiritualidade."},{"tagName":"br","void":true,"classes":["framer-text"]},{"tagName":"br","void":true,"classes":["framer-text"]},{"type":"textnode","content":"A intuição sempre foi minha bússola e orientou os meus movimentos, sem nenhum questionamento:"},{"tagName":"br","void":true,"classes":["framer-text"]},{"type":"textnode","content":"- Vivi na Austrália em 1997 e participei de um intenso e transformador retiro de silêncio"},{"tagName":"br","void":true,"classes":["framer-text"]},{"type":"textnode","content":"- Voltei ao Brasil, casei e fui mãe de um canceriano querido"}]},{"tagName":"p","type":"text","classes":["framer-text","framer-styles-preset-1pwd9y3"],"attributes":{"data-styles-preset":"sygriTHMJ","id":"if13rv"},"components":[{"type":"textnode","content":"Em 2014, já separada, senti o chamado do mar e me mudei para o Espírito Santo, achando que seria para sempre!"}]}]}]}]},{"classes":["framer-lrdne1"],"attributes":{"data-framer-name":"image","id":"iqwdb2"},"components":[{"classes":["framer-xqr60x"],"attributes":{"data-framer-name":"Image Box","id":"ic383e"},"components":[{"classes":["framer-alj5o7"],"attributes":{"data-framer-name":"Image"},"components":[{"attributes":{"data-framer-background-image-wrapper":"true","id":"irhtqi"},"components":[{"type":"image","resizable":{"ratioDefault":1},"attributes":{"decoding":"auto","width":"460","height":"580","sizes":"252px","srcset":"https://framerusercontent.com/images/HZWVllUNqiBU2Hm2fwS9JOvZl8.jpg?scale-down-to=1024&width=3322&height=3988 852w, https://framerusercontent.com/images/HZWVllUNqiBU2Hm2fwS9JOvZl8.jpg?scale-down-to=2048&width=3322&height=3988 1705w, https://framerusercontent.com/images/HZWVllUNqiBU2Hm2fwS9JOvZl8.jpg?width=3322&height=3988 3322w","src":"https://lucystrada.com/index_files/HZWVllUNqiBU2Hm2fwS9JOvZl8.jpg","alt":"About Image","id":"i06rvg"}}]}]},{"classes":["framer-1fj1z23"],"attributes":{"data-framer-component-type":"RichTextContainer","id":"icsrok"},"components":[{"tagName":"p","type":"text","classes":["framer-text","framer-styles-preset-1pwd9y3"],"attributes":{"data-styles-preset":"sygriTHMJ","id":"ipiisf"},"components":[{"type":"textnode","content":" "},{"tagName":"strong","type":"text","classes":["framer-text"],"components":[{"type":"textnode","content":"'EU SOU A EXPRESSÃO DA CONSCIÊNCIA UNIVERSAL'"}]}]}]}]}]},{"classes":["framer-fcmuro"],"attributes":{"data-framer-name":"Left","id":"ix2yzx"},"components":[{"classes":["framer-11jclh5"],"attributes":{"data-framer-component-type":"RichTextContainer","id":"i7lo73"},"components":[{"tagName":"p","type":"text","classes":["framer-text","framer-styles-preset-1pwd9y3"],"attributes":{"data-styles-preset":"sygriTHMJ","id":"ibwsuj"},"components":[{"type":"textnode","content":"Mas a vida tinha outros planos. Após um período sabático, em meditação, ouvi claramente que era hora de buscar um país de língua inglesa para expandir os horizontes do meu filho."},{"tagName":"br","void":true,"classes":["framer-text"]},{"tagName":"br","void":true,"classes":["framer-text"]},{"type":"textnode","content":"Fiz as malas e fui conduzida até Miami, EUA — onde não planejava estar, mas para onde fui guiada pela vida. "}]},{"tagName":"p","type":"text","classes":["framer-text","framer-styles-preset-1pwd9y3"],"attributes":{"data-styles-preset":"sygriTHMJ","id":"i8t37z"},"components":[{"type":"textnode","content":"Muitas coisas aconteceram por aqui:"},{"tagName":"br","void":true,"classes":["framer-text"]},{"type":"textnode","content":"- Lancei o manual \"Um Livro de Luz – 52 passos para Uma Nova Vida\" (em 2017), fruto da minha caminhada espiritual iniciada em 1984"},{"tagName":"br","void":true,"classes":["framer-text"]},{"type":"textnode","content":"- Reencontrei o amor e casei com quem considero ser a minha alma gêmea, um indiano de Gêmeos"},{"tagName":"br","void":true,"classes":["framer-text"]},{"type":"textnode","content":"- Hoje, a partir de Miami, atendo clientes do mundo todo com foco em alinhamento energético integral, através de Astrologia, Numerologia, Feng Shui, Tarot e Cura Reconectiva"},{"tagName":"br","void":true,"classes":["framer-text"]},{"tagName":"br","void":true,"classes":["framer-text"]},{"type":"textnode","content":"Aprendi que somos a expressão divina em uma experiência humana e que, ao nos libertarmos das ilusões mentais e psicológicas, podemos viver no Reino dos Céus."}]},{"tagName":"p","type":"text","classes":["framer-text","framer-styles-preset-1pwd9y3"],"attributes":{"data-styles-preset":"sygriTHMJ","id":"i20fjk"},"components":[{"type":"textnode","content":"Como Lucy Strada, vivo hoje em plenitude e serenidade, guiada pela coragem de seguir minha intuição e abraçar minha espiritualidade em cada passo."}]}]}]}],"custom-name":"personal"},{"tagName":"section","classes":["framer-fbynsp"],"attributes":{"data-framer-name":"Testimonials","id":"testimonials"},"components":[{"classes":["framer-1kpwby7-container"],"attributes":{"data-framer-appear-id":"1kpwby7","id":"iu8ksk"},"components":[{"type":"link","editable":false,"classes":["framer-C99NR","framer-1ezogyi","framer-v-t9vhw","framer-4in4od"],"attributes":{"data-framer-name":"Remix","href":"https://intermediate-angelfish-39497.rehost.page/depoimentos","target":"_blank","id":"itvmfw"},"components":[{"classes":["framer-1weh3rl"],"attributes":{"data-framer-component-type":"RichTextContainer","id":"ivhify"},"components":[{"tagName":"p","type":"text","classes":["framer-text"],"attributes":{"id":"iffz2s"},"components":[{"type":"textnode","content":"Leia Alguns Depoimentos"}]}]}]}]}],"custom-name":"depoimentos"},{"tagName":"section","classes":["framer-g1kr6p"],"attributes":{"data-framer-name":"como funciona","id":"how"},"components":[{"classes":["framer-j4ihzn"],"attributes":{"data-framer-name":"Wrapper","id":"ivm7cq"},"components":[{"classes":["framer-1u6c5rh"],"attributes":{"data-framer-name":"Top","id":"im98lq"},"components":[{"classes":["framer-581fx5-container"],"components":[{"classes":["framer-9Ndwk","framer-11cszxn","framer-v-11cszxn"],"attributes":{"data-framer-name":"Primary","id":"ig02kl"},"components":[{"classes":["framer-f9umd9"],"attributes":{"data-framer-component-type":"RichTextContainer","id":"ip3kix"},"components":[{"tagName":"p","type":"text","classes":["framer-text"],"attributes":{"id":"iqh703"},"components":[{"type":"textnode","content":"como funciona"}]}]}]}]},{"classes":["framer-cs8sno"],"attributes":{"data-framer-component-type":"RichTextContainer","id":"i4vhri"}}]},{"classes":["framer-1x2dc03"],"attributes":{"data-framer-name":"Bottom","id":"i0r9ru"},"components":[{"classes":["framer-1jqv0u4-container"],"components":[{"classes":["framer-4bccX","framer-Ki7ta","framer-HVLlm","framer-GdevH","framer-1yxlf60","framer-v-1yxlf60"],"attributes":{"data-framer-name":"Primary","id":"ie33m2"},"components":[{"classes":["framer-1oxxu2g"],"attributes":{"data-framer-component-type":"RichTextContainer","id":"i9a696"},"components":[{"tagName":"p","type":"text","classes":["framer-text","framer-styles-preset-1nvakue"],"attributes":{"data-styles-preset":"Z1BjM9Eo0"},"components":[{"type":"textnode","content":"1"}]}]},{"classes":["framer-gwwtrn"],"attributes":{"data-framer-name":"Title + Text","id":"i8rt7j"},"components":[{"classes":["framer-1t4w9ip"],"attributes":{"data-framer-component-type":"RichTextContainer","id":"itoqfg"},"components":[{"tagName":"h3","type":"hea