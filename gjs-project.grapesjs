ttributes":{"id":"i7npgi"},"components":[{"type":"textnode","content":"equilibrada,"}]},{"type":"textnode","content":" "},{"tagName":"span","type":"text","attributes":{"id":"isvfxz"},"components":[{"type":"textnode","content":"próspera"}]},{"type":"textnode","content":" "},{"tagName":"span","type":"text","attributes":{"id":"i0k6jm"},"components":[{"type":"textnode","content":"e"}]},{"type":"textnode","content":" "},{"tagName":"span","type":"text","attributes":{"id":"ilqs4i"},"components":[{"type":"textnode","content":"feliz."}]}]}]}]}]},{"classes":["framer-1na0gtc"],"attributes":{"data-framer-name":"Right","id":"i4yfyq"},"components":[{"type":"image","resizable":{"ratioDefault":1},"attributes":{"src":"https://cdn.grapesjs.com/workspaces/cmornqri700y53m51rjb9h2ka/assets/65934882-af07-4353-8750-e63f895209c7__whatsapp-image-2026-07-04-at-15.20.33.jpeg","id":"ijm267i"}}]}]}],"custom-name":"hero"},{"tagName":"section","classes":["framer-19hy9kz"],"attributes":{"data-framer-name":"MAPAS 1","id":"benefits"},"components":[{"classes":["framer-gekner"],"attributes":{"data-framer-name":"left","id":"iu41ia"},"components":[{"tagName":"h3","type":"heading","classes":["framer-text","framer-styles-preset-1rsa1iv"],"attributes":{"data-styles-preset":"PRDGHKU_m","dir":"auto","id":"isj54i"},"components":[{"tagName":"strong","type":"text","classes":["framer-text"],"attributes":{"id":"is4xb2"},"components":[{"type":"textnode","content":"Programa Mapas de Luz"}]}]},{"classes":["framer-8rf3o7"],"attributes":{"data-framer-component-type":"RichTextContainer","id":"i31ntk"},"components":[{"tagName":"h3","type":"heading","classes":["framer-text","framer-styles-preset-1pwd9y3","gjs-t-body"],"attributes":{"data-styles-preset":"sygriTHMJ","dir":"auto","id":"iezlnp"},"components":[{"type":"textnode","content":"Este programa foi desenvolvido para quem busca compreender, com profundidade, os padrões que estruturam sua vida e influenciam decisões, relacionamentos, prosperidade e direção pessoal."}]}]},{"classes":["framer-8rf3o7"],"attributes":{"data-framer-component-type":"RichTextContainer","id":"i1b9b78"},"components":[{"tagName":"h3","type":"heading","classes":["framer-text","framer-styles-preset-1pwd9y3","gjs-t-body"],"attributes":{"data-styles-preset":"sygriTHMJ","dir":"auto","id":"iezlnp-2"},"components":[{"type":"textnode","content":"Mapas de Luz não é uma leitura pontual de mapa astral. Trata-se de um processo terapêutico orientado, no qual a Astrologia Ocidental, a Astrologia Chinesa e a Numerologia Cabalística são integradas para revelar ciclos ativos, períodos de pressão, oportunidades reais e pontos cegos que costumam operar de forma inconsciente."}]}]},{"classes":["framer-8rf3o7"],"attributes":{"data-framer-component-type":"RichTextContainer","id":"iduj6mj"},"components":[{"tagName":"h3","type":"heading","classes":["framer-text","framer-styles-preset-1pwd9y3","gjs-t-body"],"attributes":{"data-styles-preset":"sygriTHMJ","dir":"auto","id":"iezlnp-2-2"},"components":[{"type":"textnode","content":"A proposta é transformar informação simbólica em consciência prática — convertendo obstáculos em clareza, força e direcionamento, com foco no equilíbrio entre vida pessoal, profissional e espiritual."},{"tagName":"b","type":"text","classes":["framer-text"],"attributes":{"id":"i19doj-2"},"components":[{"type":"textnode","content":" "}]}]}]},{"classes":["framer-15jepvu"],"attributes":{"data-framer-component-type":"RichTextContainer","id":"i5i4ef"}},{"classes":["framer-1jtez5r"],"attributes":{"data-framer-component-type":"RichTextContainer","id":"il3ifw"}},{"classes":["framer-xhkyv2"],"components":[{"type":"link","editable":false,"classes":["framer-vvz8b4","framer-tadt63"],"attributes":{"data-framer-appear-id":"vvz8b4","data-framer-name":"Button","href":"https://lucystrada.substack.com/p/mapas","target":"_blank","rel":"noopener","id":"i6mz1o"},"components":[{"classes":["framer-1wprny5"],"attributes":{"data-framer-component-type":"RichTextContainer","id":"ilsh1s"},"components":[{"tagName":"p","type":"text","classes":["framer-text"],"attributes":{"dir":"auto","id":"i91dlj"},"components":[{"type":"textnode","content":"Estrutura do Programa"}]}]}]},{"classes":["framer-1i6qno3-container"],"attributes":{"data-framer-appear-id":"1i6qno3","id":"itv63h"},"components":[{"type":"link","editable":false,"classes":["framer-C99NR","framer-1ezogyi","framer-v-1ezogyi","framer-4in4od"],"attributes":{"data-framer-name":"Primary","href":"https://cal.com/lucystrada/mapas","target":"_blank","rel":"noopener","id":"imfuwj"},"components":[{"classes":["framer-1weh3rl"],"attributes":{"data-framer-component-type":"RichTextContainer","id":"i4k22k"},"components":[{"tagName":"p","type":"text","classes":["framer-text"],"attributes":{"id":"ibvnht"},"components":[{"type":"textnode","content":"Agende um Encontro"}]}]}]}]}]}],"custom-name":"left"},{"classes":["framer-etg3uf"],"attributes":{"data-framer-name":"right","id":"i2akbg"},"components":[{"tagName":"h3","type":"heading","classes":["framer-text","framer-styles-preset-1rsa1iv"],"attributes":{"data-styles-preset":"PRDGHKU_m","dir":"auto","id":"ijdt4v"},"components":[{"tagName":"strong","type":"text","classes":["framer-text"],"attributes":{"id":"ixozdk"},"components":[{"type":"textnode","content":"AstroTherapia"}]}]},{"classes":["framer-8rf3o7"],"attributes":{"data-framer-component-type":"RichTextContainer","id":"iesdd53"},"components":[{"tagName":"h3","type":"heading","classes":["framer-text","framer-styles-preset-1pwd9y3","gjs-t-body"],"attributes":{"data-styles-preset":"sygriTHMJ","dir":"auto","id":"iezlnp-3"},"components":[{"type":"textnode","content":"Este trabalho terapêutico tem como foco o autoconhecimento profundo e o reposicionamento interno diante dos desafios da vida."}]}]},{"classes":["framer-8rf3o7"],"attributes":{"data-framer-component-type":"RichTextContainer","id":"iw59ivk"},"components":[{"tagName":"h3","type":"heading","classes":["framer-text","framer-styles-preset-1pwd9y3","gjs-t-body"],"attributes":{"data-styles-preset":"sygriTHMJ","dir":"auto","id":"iezlnp-3-4"},"components":[{"type":"textnode","content":"A abordagem integra princípios da Psicologia Transpessoal com a linguagem simbólica da Astrologia Ocidental, Astrologia Chinesa e Numerologia Cabalística, utilizadas como base de leitura de padrões, arquétipos e ciclos de consciência."}]}]},{"classes":["framer-8rf3o7"],"attributes":{"data-framer-component-type":"RichTextContainer","id":"i23mikl"},"components":[{"tagName":"h3","type":"heading","classes":["framer-text","framer-styles-preset-1pwd9y3","gjs-t-body"],"attributes":{"data-styles-preset":"sygriTHMJ","dir":"auto","id":"iezlnp-3-3"},"components":[{"type":"textnode","content":"Não se trata de leitura ou atualização de mapa astral, nem de previsões. O processo é orientado pelas questões trazidas em sessão, buscando identificar bloqueios, repetições e potenciais não integrados, favorecendo escolhas mais conscientes e alinhadas."}]}]},{"classes":["framer-n4w0dc"],"attributes":{"id":"i5dhkt"},"components":[{"type":"link","editable":false,"classes":["framer-vvz8b4","framer-tadt63"],"attributes":{"data-framer-appear-id":"vvz8b4","data-framer-name":"Button","href":"https://lucystrada.substack.com/p/mapas-astrotherapia?r=1vm0qr","target":"_blank","rel":"noopener","id":"ib461gi","title":""},"components":[{"classes":["framer-1wprny5"],"attributes":{"data-framer-component-type":"RichTextContainer","id":"iu7319q"},"components":[{"tagName":"p","type":"text","classes":["framer-text"],"attributes":{"dir":"auto","id":"i40m4ta"},"components":[{"type":"textnode","content":"Saiba Mais"}],"custom-name":"Saiba Mais"}]}],"custom-name":"Link"},{"classes":["framer-1f5zu30-container"],"attributes":{"data-framer-appear-id":"1f5zu30","id":"ik2j34"},"components":[{"type":"link","editable":false,"classes":["framer-C99NR","framer-1ezogyi","framer-v-1ezogyi","framer-4in4od"],"attributes":{"data-framer-name":"Primary","href":"https://cal.com/lucystrada/astrotherapia","