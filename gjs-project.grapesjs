a-framer-component-type":"RichTextContainer","id":"i7ybgh"},"components":[{"tagName":"p","type":"text","classes":["framer-text","framer-styles-preset-e7e1gy"],"attributes":{"data-styles-preset":"iUCwKohD7"},"components":[{"type":"textnode","content":"A Numerologia Cabalística elimina desafios e maximiza sucesso, prosperidade, saúde e equilíbrio nos relacionamentos. A harmonização acontece através de acentuação gráfica e pode ser utilizada para nomes pessoais e profissionais, razão social e nome fantasia de negócios, assim como para registro de nome de nascimento de bebês."}]}]},{"type":"link","editable":false,"classes":["framer-xrtynf","framer-1sqjor8"],"attributes":{"data-framer-appear-id":"xrtynf","data-framer-name":"Button","href":"https://lucystrada.substack.com/p/numerologia-cabalistica?r=1vm0qr","rel":"noopener","id":"ipa42f"},"components":[{"classes":["framer-d4fmnr"],"attributes":{"data-framer-component-type":"RichTextContainer","id":"ixpy65"},"components":[{"tagName":"p","type":"text","classes":["framer-text"],"attributes":{"id":"ise53u"},"components":[{"type":"textnode","content":"Saiba Mais"}]}]}]}]}]}]},{"classes":["framer-1c6rnk-container"],"attributes":{"data-framer-name":"numerologia","name":"numerologia","id":"ixq68h"},"components":[{"classes":["framer-rTGZS","framer-HVLlm","framer-GdevH","framer-1owqart","framer-v-1owqart"],"attributes":{"name":"numerologia","data-framer-name":"Desktop","id":"i1i0ij"},"components":[{"classes":["framer-pruedm"],"attributes":{"id":"i2i7ov"},"components":[{"classes":["framer-1r4lnvt"],"attributes":{"data-framer-name":"Gradient","id":"i5i0ip"}},{"classes":["framer-y4eqsl"],"attributes":{"data-framer-name":"Image","id":"isqhft"},"components":[{"attributes":{"data-framer-background-image-wrapper":"true","id":"ic4i4i"},"components":[{"type":"image","resizable":{"ratioDefault":1},"attributes":{"decoding":"auto","width":"100","height":"376","sizes":"100px","srcset":"https://framerusercontent.com/images/8N0yWW6MUh1H5Iaa276SQ6QYY.jpg?scale-down-to=512&width=1024&height=768 512w, https://framerusercontent.com/images/8N0yWW6MUh1H5Iaa276SQ6QYY.jpg?width=1024&height=768 1024w","src":"https://lucystrada.com/index_files/8N0yWW6MUh1H5Iaa276SQ6QYY.jpg","alt":"","id":"invvsl"}}]}]}]},{"classes":["framer-ysjvn"],"attributes":{"id":"i7neik"},"components":[{"classes":["framer-13olohv"],"attributes":{"data-framer-component-type":"RichTextContainer","id":"i6dg1d"},"components":[{"tagName":"h3","type":"heading","classes":["framer-text","framer-styles-preset-1rsa1iv"],"attributes":{"data-styles-preset":"PRDGHKU_m"},"components":[{"type":"textnode","content":"Feng Shui Tradicional"}]}]},{"classes":["framer-16139vn"],"attributes":{"data-framer-component-type":"RichTextContainer","id":"im9j2j"},"components":[{"tagName":"p","type":"text","classes":["framer-text","framer-styles-preset-e7e1gy"],"attributes":{"data-styles-preset":"iUCwKohD7"},"components":[{"type":"textnode","content":"O Feng Shui Tradicional (Xuan Kong Fei Xin) propõe-se harmonizar o imóvel (tanto residencial quanto empresarial) para que a energia flua com equilíbrio, maximizando saúde, prosperidade e bem-estar. Com essa técnica localizamos as áreas favoráveis, para maximizar os seus potenciais positivos, e também as áreas desafiadoras, e assim minimizar instabilidades emocionais e financeiras, enfermidades e desarmonias nos relacionamentos."}]}]},{"type":"link","editable":false,"classes":["framer-xrtynf","framer-1sqjor8"],"attributes":{"data-framer-appear-id":"xrtynf","data-framer-name":"Button","href":"https://lucystrada.substack.com/p/moradia-saudavel?r=1vm0qr","rel":"noopener","id":"ibhfev"},"components":[{"classes":["framer-d4fmnr"],"attributes":{"data-framer-component-type":"RichTextContainer","id":"i8u2os"},"components":[{"tagName":"p","type":"text","classes":["framer-text"],"attributes":{"id":"iao5qi"},"components":[{"type":"textnode","content":"Saiba Mais"}]}]}]}]}]}]},{"classes":["framer-1juvz4f-container"],"attributes":{"data-frame